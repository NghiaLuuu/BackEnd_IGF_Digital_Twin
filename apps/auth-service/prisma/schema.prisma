generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("AUTH_DATABASE_URL")
}

model AuthUser {
  userId   String   @id @map("user_id")
  username String   @unique
  password String
  roles    String[] @default([])

  @@map("auth_users")
}
